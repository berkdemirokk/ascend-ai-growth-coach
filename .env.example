# Frontend'in baglanacagi proxy adresi.
VITE_AI_BACKEND_URL="http://127.0.0.1:8787"

# Profile ve gorev senkronu icin session backend adresi.
# Bos birakilirsa VITE_AI_BACKEND_URL kullanilir.
VITE_PERSISTENCE_URL="http://127.0.0.1:8787"

# Proxy'nin baglanacagi Ollama adresi.
OLLAMA_BASE_URL="http://192.168.68.105:11434"

# Kullanilacak model
OLLAMA_MODEL="qwen2.5:3b"

# Proxy portu
AI_PROXY_PORT="8787"

# iOS client tarafinda RevenueCat public API key (app-specific)
VITE_REVENUECAT_IOS_API_KEY="appl_XXXX"

# Client tarafinda premium entitlement id (RevenueCat dashboard ile ayni olmali)
VITE_REVENUECAT_ENTITLEMENT_ID="premium"

# Opsiyonel: belirli bir offering id kullanmak istersen
VITE_REVENUECAT_OFFERING_ID=""

# Server tarafinda RevenueCat Secret API key (sadece backend)
REVENUECAT_SECRET_API_KEY="sk_XXXX"

# Server tarafinda kontrol edilecek entitlement id
REVENUECAT_ENTITLEMENT_ID="premium"

# Sadece test/preview icin; public release'te false kalmali
ENABLE_BILLING_PREVIEW="false"
