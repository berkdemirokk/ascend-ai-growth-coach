# RevenueCat iOS API Key (get from RevenueCat Dashboard)
REVENUECAT_IOS_API_KEY=appl_XXXXXXXXXXXXXXXX

# RevenueCat Entitlement Identifier
REVENUECAT_ENTITLEMENT_ID=premium

# RevenueCat Offering Identifier (optional)
REVENUECAT_OFFERING_ID=default

# AdMob iOS App ID (get from AdMob)
ADMOB_IOS_APP_ID=ca-app-pub-0000000000000000~0000000000

# AdMob iOS Interstitial Unit ID (get from AdMob)
ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-0000000000000000/0000000000

# EAS Project ID (get from `eas init`)
EAS_PROJECT_ID=replace-with-eas-project-id
