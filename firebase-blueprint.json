{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "The core profile data for a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's display name" },
        "selectedPath": { "type": "string", "enum": ["fitness", "culture", "social", "entertainment", "career", "general"], "description": "The chosen growth path" },
        "goals": { "type": "array", "items": { "type": "string" }, "description": "List of user goals" },
        "level": { "type": "integer", "description": "User's current level" },
        "experience": { "type": "integer", "description": "User's current experience points" },
        "streak": { "type": "integer", "description": "Current daily streak" },
        "lastCompletedDate": { "type": "string", "format": "date", "description": "Last date a task was completed (YYYY-MM-DD)" },
        "notificationsEnabled": { "type": "boolean", "description": "Whether notifications are enabled" },
        "reminderTime": { "type": "string", "description": "Daily reminder time (HH:mm)" },
        "isPremium": { "type": "boolean", "description": "Whether the user has premium status" },
        "badges": { 
          "type": "array", 
          "items": { "$ref": "Badge" },
          "description": "List of earned badges"
        }
      },
      "required": ["name", "level", "experience", "streak", "notificationsEnabled", "isPremium"]
    },
    "Badge": {
      "title": "Badge",
      "description": "A badge earned by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "icon": { "type": "string" },
        "description": { "type": "string" },
        "earnedAt": { "type": "integer", "description": "Timestamp when earned" }
      },
      "required": ["id", "title", "icon", "description", "earnedAt"]
    },
    "DailyTask": {
      "title": "Daily Task",
      "description": "A task for the user to complete.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "completed": { "type": "boolean" },
        "category": { "type": "string", "enum": ["fitness", "culture", "social", "entertainment", "career", "general"] },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "reminderTime": { "type": "string", "description": "Reminder time for the task" }
      },
      "required": ["id", "title", "completed", "category", "priority"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A message in the AI Coach chat.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "integer" }
      },
      "required": ["role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "DailyTask",
      "description": "User's daily tasks"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "User's chat history with the AI Coach"
    }
  }
}
