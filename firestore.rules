rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == 'berkkdemirok@gmail.com' && request.auth.token.email_verified == true)
        );
    }

    function hasOnlyAllowedFields(data, allowedFields) {
      return data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(data, requiredFields) {
      return data.keys().hasAll(requiredFields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isValidTime(timeStr) {
      return timeStr is string && timeStr.matches('^\\d{2}:\\d{2}$');
    }

    function ownerProfileFields() {
      return [
        'name',
        'selectedPath',
        'goals',
        'notificationsEnabled',
        'reminderTime',
        'theme',
        'personality',
        'height',
        'weight',
        'hobbies',
        'analysis',
        'currentLevel',
        'intensity',
        'dailyTime'
      ];
    }

    function allProfileFields() {
      return [
        'name',
        'selectedPath',
        'goals',
        'notificationsEnabled',
        'reminderTime',
        'theme',
        'personality',
        'height',
        'weight',
        'hobbies',
        'analysis',
        'currentLevel',
        'intensity',
        'dailyTime',
        'isPremium',
        'level',
        'experience',
        'streak',
        'lastCompletedDate',
        'badges',
        'role'
      ];
    }

    function isValidProfileDocument(data) {
      return hasOnlyAllowedFields(data, allProfileFields()) &&
        hasRequiredFields(data, ['name', 'notificationsEnabled']) &&
        data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
        (!('selectedPath' in data) || data.selectedPath in ['fitness', 'culture', 'social', 'entertainment', 'career', 'general', null]) &&
        (!('goals' in data) || (data.goals is list && data.goals.size() <= 50)) &&
        data.notificationsEnabled is bool &&
        (!('reminderTime' in data) || isValidTime(data.reminderTime)) &&
        (!('theme' in data) || data.theme in ['light', 'dark']) &&
        (!('personality' in data) || data.personality is string) &&
        (!('height' in data) || (data.height is int || data.height is float)) &&
        (!('weight' in data) || (data.weight is int || data.weight is float)) &&
        (!('hobbies' in data) || data.hobbies is list) &&
        (!('analysis' in data) || data.analysis is string) &&
        (!('currentLevel' in data) || data.currentLevel in ['beginner', 'intermediate', 'advanced']) &&
        (!('intensity' in data) || data.intensity in ['casual', 'regular', 'intense']) &&
        (!('dailyTime' in data) || data.dailyTime in ['15m', '30m', '1h', '2h+']) &&
        (!('isPremium' in data) || data.isPremium is bool) &&
        (!('level' in data) || (data.level is int && data.level >= 1)) &&
        (!('experience' in data) || (data.experience is int && data.experience >= 0)) &&
        (!('streak' in data) || (data.streak is int && data.streak >= 0)) &&
        (!('lastCompletedDate' in data) || isValidDateString(data.lastCompletedDate)) &&
        (!('badges' in data) || data.badges is list) &&
        (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidEntitlements(data) {
      return hasOnlyAllowedFields(data, ['isPremium', 'grantedBy', 'updatedAt']) &&
        hasRequiredFields(data, ['isPremium', 'updatedAt']) &&
        data.isPremium is bool &&
        data.updatedAt is timestamp &&
        (!('grantedBy' in data) || data.grantedBy is string);
    }

    function allTaskFields() {
      return ['id', 'title', 'description', 'completed', 'createdAt', 'completedAt', 'category', 'priority', 'reminderTime', 'source'];
    }

    function isValidTaskDocument(data) {
      return hasOnlyAllowedFields(data, allTaskFields()) &&
        hasRequiredFields(data, ['id', 'title', 'completed', 'category', 'priority']) &&
        data.id is string &&
        data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
        (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
        data.completed is bool &&
        data.category in ['fitness', 'culture', 'social', 'entertainment', 'career', 'general'] &&
        data.priority in ['high', 'medium', 'low'] &&
        (!('reminderTime' in data) || isValidTime(data.reminderTime)) &&
        (!('source' in data) || data.source in ['generated', 'custom', 'migrated', 'preview']) &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        (!('completedAt' in data) || data.completedAt is timestamp);
    }

    function isValidOwnerTaskCreate(data, taskId) {
      return isValidTaskDocument(data) &&
        data.id == taskId &&
        data.completed == false &&
        !('completedAt' in data) &&
        ('source' in data) &&
        data.source in ['generated', 'custom', 'preview'] &&
        ('createdAt' in data) &&
        data.createdAt == request.time;
    }

    function isValidTaskSourceTransition() {
      return
        (!('source' in resource.data) && !('source' in request.resource.data)) ||
        (('source' in resource.data) && ('source' in request.resource.data) && request.resource.data.source == resource.data.source);
    }

    function isValidTaskCreatedAtTransition() {
      return
        (!('createdAt' in resource.data) && !('createdAt' in request.resource.data)) ||
        (('createdAt' in resource.data) && ('createdAt' in request.resource.data) && request.resource.data.createdAt == resource.data.createdAt);
    }

    function isValidTaskCompletionTransition() {
      return
        (!('completedAt' in resource.data) && !('completedAt' in request.resource.data)) ||
        (!('completedAt' in resource.data) && request.resource.data.completed == true && request.resource.data.completedAt == request.time) ||
        (('completedAt' in resource.data) && ('completedAt' in request.resource.data) && request.resource.data.completedAt == resource.data.completedAt);
    }

    function isValidMessage(data) {
      return hasRequiredFields(data, ['role', 'text', 'timestamp']) &&
        hasOnlyAllowedFields(data, ['role', 'text', 'timestamp']) &&
        data.role in ['user', 'model'] &&
        data.text is string && data.text.size() >= 1 && data.text.size() <= 5000 &&
        data.timestamp is int;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if
        (
          isOwner(userId) &&
          hasOnlyAllowedFields(request.resource.data, ownerProfileFields()) &&
          isValidProfileDocument(request.resource.data)
        ) ||
        (
          isAdmin() &&
          isValidProfileDocument(request.resource.data)
        );

      allow update: if
        (
          isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownerProfileFields()) &&
          isValidProfileDocument(request.resource.data)
        ) ||
        (
          isAdmin() &&
          isValidProfileDocument(request.resource.data)
        );

      match /tasks/{taskId} {
        allow read: if isOwner(userId) || isAdmin();

        allow create: if
          (isOwner(userId) && isValidOwnerTaskCreate(request.resource.data, taskId)) ||
          (isAdmin() && isValidTaskDocument(request.resource.data));

        allow update: if
          (
            isOwner(userId) &&
            isValidTaskDocument(request.resource.data) &&
            request.resource.data.id == taskId &&
            request.resource.data.id == resource.data.id &&
            isValidTaskSourceTransition() &&
            isValidTaskCreatedAtTransition() &&
            isValidTaskCompletionTransition()
          ) ||
          (
            isAdmin() &&
            isValidTaskDocument(request.resource.data)
          );

        allow delete: if isOwner(userId) || isAdmin();
      }

      match /messages/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidMessage(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /userEntitlements/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin() && isValidEntitlements(request.resource.data);
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
